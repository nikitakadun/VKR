#VRML_SIM R2025a utf8

EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/objects/backgrounds/protos/TexturedBackground.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/objects/backgrounds/protos/TexturedBackgroundLight.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/objects/floors/protos/RectangleArena.proto"

WorldInfo {
  info [
    "SAHR - Correct Suspension System"
  ]
  basicTimeStep 16
  gravity 0 -9.81 0
  contactProperties [
    ContactProperties {
      coulombFriction [
        0.8
      ]
    }
  ]
}
Viewpoint {
  orientation -0.09142843462220382 0.19894784048159808 0.9757359264218173 3.017377055297567
  position 2.5 0.8 1.5
  follow "rectangle arena"
}
TexturedBackground {
}
TexturedBackgroundLight {
}
RectangleArena {
  floorSize 4 3
}

# ===== 1. СТОЙКА (ОТДЕЛЬНЫЙ НЕПОДВИЖНЫЙ SOLID) =====
Solid {
  name "central_pillar"
  translation 0 0.6 0
  children [
    # Основная стойка
    Shape {
      appearance PBRAppearance {
        baseColor 0.5 0.5 0.5
        roughness 0.4
      }
      geometry Cylinder {
        height 1.5
        radius 0.05
      }
    }
    # Основание
    Transform {
      translation 0 -0.75 0
      children [
        Shape {
          appearance PBRAppearance {
            baseColor 0.3 0.3 0.3
          }
          geometry Cylinder {
            height 0.1
            radius 0.25
          }
        }
      ]
    }
  ]
  boundingObject Group {
    children [
      Cylinder {
        height 1.5
        radius 0.05
      }
      Transform {
        translation 0 -0.75 0
        children [
          Cylinder {
            height 0.1
            radius 0.25
          }
        ]
      }
    ]
  }
  physics Physics {
    mass -1  # неподвижная
  }
}

# ===== 2. КОЛЬЦО-РОБОТ (НОСИТЕЛЬ) =====
Robot {
  name "suspension_system"
  translation 0 0.6 0  # на вершине стойки
  children [
    # Визуальное кольцо
    Shape {
      appearance PBRAppearance {
        baseColor 0 0.8 0
      }
      geometry Cylinder {
        height 0.1
        radius 0.08
      }
    }
    
    # SliderJoint для вертикального движения
    SliderJoint {
      jointParameters JointParameters {
        axis 0 1 0
        minStop 0.2
        maxStop 1.0
      }
      endPoint Solid {
        translation 0 0 0
        children [
          # Каретка
          Shape {
            appearance PBRAppearance {
              baseColor 1 1 0
            }
            geometry Sphere {
              radius 0.08
            }
          }
          
          # BallJoint для свободного подвеса
          BallJoint {
            jointParameters BallJointParameters {
              anchor 0 0 0
              dampingConstant 0.1
            }
            jointParameters2 JointParameters {
              axis 1 0 0
            }
            jointParameters3 JointParameters {
              axis 0 1 0
            }
            endPoint Solid {
              translation 0.4 0 0  # смещение от стойки
              children [
                # ===== ВАШ РОБОТ SAHR =====
                Robot {
                  name "SAHR_Best"
                  translation 0 0 0
                  rotation 1 0 0 1.5708
                  controller "sahr_basic"
                  children [
                    # Корпус (красный)
                    Pose {
                      translation 0 0.1 0
                      children [
                        Shape {
                          appearance Appearance {
                            material Material {
                              diffuseColor 1 0 0
                            }
                          }
                          geometry Box {
                            size 0.2 0.2 0.08
                          }
                        }
                        
                        # Первый BallJoint (штанга)
                        BallJoint {
                          jointParameters BallJointParameters {
                            dampingConstant 0.1
                          }
                          jointParameters2 JointParameters {
                            axis 1 0 0
                          }
                          jointParameters3 JointParameters {
                            axis 0 1 0
                          }
                          device [
                            RotationalMotor {
                              name "ball1_motor_x"
                            }
                          ]
                          device2 [
                            RotationalMotor {
                              name "ball1_motor_y"
                              minPosition -1.57
                              maxPosition 1.57
                            }
                          ]
                          device3 [
                            RotationalMotor {
                              name "ball1_motor_z"
                            }
                          ]
                          endPoint Solid {
                            translation -0.0124 0.0157 0.0626
                            rotation -0.1246 -0.9653 0.2296 0.0761
                            children [
                              Solid {
                                translation 0 0 0.54
                                rotation 0 0 1 1.5708
                                children [
                                  # Второй BallJoint
                                  BallJoint {
                                    jointParameters BallJointParameters {
                                      dampingConstant 0.1
                                    }
                                    jointParameters2 JointParameters {
                                      axis 1 0 0
                                    }
                                    jointParameters3 JointParameters {
                                      axis 0 1 0
                                    }
                                    device [
                                      RotationalMotor {
                                        name "ball2_motor_x"
                                      }
                                    ]
                                    device2 [
                                      RotationalMotor {
                                        name "ball2_motor_y"
                                        minPosition -1.57
                                        maxPosition 1.57
                                      }
                                    ]
                                    device3 [
                                      RotationalMotor {
                                        name "ball2_motor_z"
                                      }
                                    ]
                                    endPoint Solid {
                                      translation -0.00643 0.00418 0.53279
                                      children [
                                        Shape {
                                          appearance PBRAppearance {}
                                          geometry Sphere {
                                            radius 0.04
                                          }
                                        }
                                      ]
                                      boundingObject Sphere {
                                        radius 0.04
                                      }
                                      physics Physics {
                                        mass 0.05
                                      }
                                    }
                                  }
                                  
                                  # Штанга
                                  Shape {
                                    appearance Appearance {
                                      material Material {
                                        diffuseColor 0.8 0.4 0.2
                                      }
                                    }
                                    geometry Cylinder {
                                      height 1
                                      radius 0.02
                                    }
                                  }
                                ]
                                boundingObject Cylinder {
                                  height 1
                                  radius 0.02
                                }
                                physics Physics {
                                  mass 0.1
                                }
                              }
                              
                              # Дополнительная сфера
                              Shape {
                                appearance PBRAppearance {}
                                geometry Sphere {
                                  radius 0.027
                                }
                              }
                            ]
                            boundingObject Sphere {
                              radius 0.027
                            }
                            physics Physics {
                              mass 0.03
                            }
                          }
                        }
                      ]
                    }
                    
                    # Нога робота
                    HingeJoint {
                      jointParameters HingeJointParameters {
                        axis 0 0 1
                        anchor 0 0.1 0
                        dampingConstant 0.23
                      }
                      device [
                        RotationalMotor {
                          name "hip_motor"
                          minPosition -1.047
                          maxPosition 1.047
                          maxTorque 5.5
                        }
                        PositionSensor {
                          name "hip_sensor"
                        }
                      ]
                      endPoint Solid {
                        translation -0.00578 0.08437 0.00017
                        rotation -0.88631 0.46308 -0.00159 0.00288
                        children [
                          Pose {
                            translation 0 -0.05 0
                            children [
                              Shape {
                                appearance Appearance {
                                  material Material {
                                    diffuseColor 0 0 1
                                  }
                                }
                                geometry Cylinder {
                                  height 0.1
                                  radius 0.01
                                }
                              }
                            ]
                          }
                          
                          # Пружинная нога
                          SliderJoint {
                            jointParameters JointParameters {
                              axis 0 -1 0
                              minStop -0.15
                              maxStop 0.15
                              springConstant 4800
                              dampingConstant 6
                            }
                            device [
                              PositionSensor {
                                name "leg_sensor"
                              }
                            ]
                            endPoint Solid {
                              translation 0.00271 -0.06 -0.02497
                              rotation 0.99979 -0.01842 0.00885 -0.00058
                              children [
                                Pose {
                                  translation 0 -0.1 0
                                  rotation 1 0 0 1.5708
                                  children [
                                    Shape {
                                      appearance Appearance {
                                        material Material {
                                          diffuseColor 1 1 0
                                        }
                                      }
                                      geometry Cylinder {
                                        height 0.15
                                        radius 0.008
                                      }
                                    }
                                  ]
                                }
                                Pose {
                                  translation 0 -0.175 0
                                  children [
                                    Shape {
                                      appearance Appearance {
                                        material Material {
                                          diffuseColor 0 1 0
                                        }
                                      }
                                      geometry Cylinder {
                                        height 0.15
                                        radius 0.007
                                      }
                                    }
                                  ]
                                }
                                Pose {
                                  translation 0 -0.25 0
                                  children [
                                    Shape {
                                      appearance Appearance {
                                        material Material {
                                          diffuseColor 0.5 0.5 0.5
                                        }
                                      }
                                      geometry Sphere {
                                        radius 0.02
                                      }
                                    }
                                  ]
                                }
                                TouchSensor {
                                  name "foot_sensor"
                                  type "force"
                                }
                              ]
                              name "leg_foot_assembly"
                              boundingObject Group {
                                children [
                                  Pose {
                                    translation 0 -0.1 0
                                    rotation 1 0 0 1.5708
                                    children [
                                      Cylinder {
                                        height 0.15
                                        radius 0.008
                                      }
                                    ]
                                  }
                                  Pose {
                                    translation 0 -0.175 0
                                    children [
                                      Cylinder {
                                        height 0.15
                                        radius 0.007
                                      }
                                    ]
                                  }
                                  Pose {
                                    translation 0 -0.25 0
                                    children [
                                      Sphere {
                                        radius 0.02
                                      }
                                    ]
                                  }
                                ]
                              }
                              physics Physics {
                                density -1
                                mass 0.5
                              }
                            }
                          }
                        ]
                        name "thigh_assembly"
                        boundingObject Pose {
                          translation 0 -0.05 0
                          children [
                            Cylinder {
                              height 0.1
                              radius 0.01
                            }
                          ]
                        }
                        physics Physics {
                          density -1
                          mass 0.1
                        }
                      }
                    }
                    
                    GPS {
                      name "body_gps"
                    }
                    InertialUnit {
                      name "body_imu"
                    }
                  ]
                  boundingObject Group {
                    children [
                      Pose {
                        translation 0 0.1 0
                        children [
                          Box {
                            size 0.2 0.2 0.08
                          }
                        ]
                      }
                    ]
                  }
                  physics Physics {
                    density -1
                    mass 5
                    centerOfMass [
                      0.05 0.3 0
                    ]
                  }
                }
              ]
              boundingObject Sphere {
                radius 0.1
              }
              physics Physics {
                mass 0.2
              }
            }
          }
        ]
        boundingObject Sphere {
          radius 0.1
        }
        physics Physics {
          mass 0.1
        }
      }
    }
  ]
  boundingObject Cylinder {
    height 0.1
    radius 0.08
  }
  physics Physics {
    mass -1  # кольцо неподвижно
  }
}